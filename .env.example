# ============================================================
#  Stalker Strike — Environment Configuration
#  Copy this to .env and fill in your values
# ============================================================

# ── Telegram Bot (auto-send reports to your Telegram) ───────
# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=
# Your chat ID (use @userinfobot to find it)
TELEGRAM_CHAT_ID=

# ── API Keys (optional — enhance results) ───────────────────
# ExifTools.com API key (for EXIF metadata extraction)
# Get free key at: https://exiftools.com/api
EXIFTOOLS_API_KEY=

# Numverify phone API (1000 req/month free)
# Get at: https://numverify.com/
NUMVERIFY_API_KEY=

# Veriphone phone API (1000 req/month free, best for Indonesia)
# Get at: https://veriphone.io/
VERIPHONE_API_KEY=

# ── Maigret Settings ─────────────────────────────────────────
# Max seconds per site check (reduce for faster scans on slow connections)
MAIGRET_TIMEOUT=60
# Max sites to check (reduce to 100-200 for Termux battery saving)
MAIGRET_MAX_SITES=300

# ── Output Settings ──────────────────────────────────────────
OUTPUT_DIR=output
IMAGE_DIR=output/images

# ── Stealth Mode ─────────────────────────────────────────────
# Enable random delays + header rotation (slower but harder to detect)
STEALTH_MODE=false
# Rotate User-Agent per request (recommended: true)
STEALTH_RANDOM_UA=true
# Base delay between requests in seconds
REQUEST_DELAY=0.5

# ── Face Search ──────────────────────────────────────────────
# Max avatar images to run through face search engines
FACE_SEARCH_MAX_AVATARS=3

# ── Local Database ───────────────────────────────────────────
# Directory containing local breach databases (CSV/JSON)
LOCALDB_DIR=databaselocal
